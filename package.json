{
  "name": "seedance-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Seedance AI 视频生成工具",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch src/index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx tsc -b && npx vite build",
    "preview": "cd client && npx vite preview",
    "start": "cd server && node src/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.0"
  }
}
